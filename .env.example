# =========================================================
# Скопируйте этот файл в .env и заполните своими значениями
#   cp .env.example .env
# =========================================================

# Токен Telegram-бота от @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Telegram ID администраторов через запятую (без пробелов)
# Узнать свой ID можно у @userinfobot
ADMIN_IDS=123456789

# --- Пути к данным ---
# Папка с исходными документами (.pdf, .txt) для индексации
DOCUMENTS_DIR=./data/documents
# Папка для постоянного хранения векторной БД Chroma
CHROMA_DIR=./data/chroma

# --- Модель эмбеддингов ---
# Мультиязычная модель, хорошо работает с русским
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# --- Параметры RAG-поиска ---
RAG_TOP_K=15
RELEVANCE_THRESHOLD=0.60
MIN_RELEVANT_CHUNKS=2

# --- Локальная LLM через Ollama ---
# Установите Ollama: https://ollama.com
# Затем выполните: ollama pull qwen2.5:14b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b
